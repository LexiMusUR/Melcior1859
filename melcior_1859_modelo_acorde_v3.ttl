melcior:MayorCon5aAumentada rdf:type owl:NamedIndividual ;
                            leximus:esAlteracionDe melcior:AcordeConsonante ;
                            leximus:ordenEnClasificacion 8 .


###  http://leximus.es/source/melcior1859#MayorCon5aDiminuta
melcior:MayorCon5aDiminuta rdf:type owl:NamedIndividual ;
                           leximus:esAlteracionDe melcior:AcordeConsonante ;
                           leximus:ordenEnClasificacion 13 .


###  http://leximus.es/source/melcior1859#Melcior
melcior:Melcior rdf:type owl:NamedIndividual ,
                         prov:Agent ;
                rdfs:comment "Autor del Diccionario enciclopedico de la musica (1859)."@es ;
                rdfs:label "Carlos Jose Melcior" .


###  http://leximus.es/source/melcior1859#MetaforaClaroOscuro
melcior:MetaforaClaroOscuro rdf:type owl:NamedIndividual ,
                                     cidoc:E89_Propositional_Object ;
                            leximus:esAdoptadaPor melcior:Melcior ;
                            leximus:nivelEvidencia "TEXTUAL"@es ;
                            cidoc:P67_refers_to melcior:AcordeConsonante ,
                                                melcior:AcordeDisonante ;
                            rdfs:comment "Melcior compara la mezcla consonancia/disonancia con el claro y oscuro en la pintura: 'Esta mezcla es a lo que el claro y oscuro en la pintura' (acorde, frase 7); 'son como las sombras en la pintura, que hacen resaltar mas los objetos' (disonancia, frase 58). Analogia entre percepcion visual y auditiva."@es ;
                            rdfs:label "metafora del claro y oscuro en la pintura"@es .


###  http://leximus.es/source/melcior1859#ModeloDeProgresion
melcior:ModeloDeProgresion rdf:type owl:NamedIndividual ;
                           leximus:fuenteEntry "melcior_1859_progresion_o_marcha_armonica" .


