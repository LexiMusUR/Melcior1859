melcior:Nota rdf:type owl:NamedIndividual ;
             leximus:fuenteEntry "melcior_1859_notas_de_la_musica" .


###  http://leximus.es/source/melcior1859#NotaExtranaAlAcorde
melcior:NotaExtranaAlAcorde rdf:type owl:NamedIndividual ;
                            leximus:fuenteEntry "melcior_1859_armonia" .


