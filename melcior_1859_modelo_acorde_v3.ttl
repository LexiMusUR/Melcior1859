melcior:Nota_s1 rdf:type owl:NamedIndividual ,
                         ontolex:LexicalSense ;
                rdfs:label "nota: signo grafico"@es ;
                skos:definition "signo que representa un sonido en la escritura musical"@es ;
                ontolex:reference melcior:Nota .


###  http://leximus.es/source/melcior1859#Nota_s2
melcior:Nota_s2 rdf:type owl:NamedIndividual ,
                         ontolex:LexicalSense ;
                rdfs:label "nota: saber de musica"@es ;
                skos:definition "saber de musica (uso coloquial: 'tener nota')"@es .


