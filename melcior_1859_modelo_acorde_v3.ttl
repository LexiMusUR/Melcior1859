                 leximus:fuenteEntry "melcior_1859_ligadura" .


###  http://leximus.es/source/melcior1859#Marcha_s1
melcior:Marcha_s1 rdf:type owl:NamedIndividual ,
                           ontolex:LexicalSense ;
                  rdfs:label "marcha: pieza militar"@es ;
                  skos:definition "tocata que se ejecuta con instrumentos de viento, acompanada muchas veces con cajas de guerra"@es .


###  http://leximus.es/source/melcior1859#Marcha_s2
melcior:Marcha_s2 rdf:type owl:NamedIndividual ,
                           ontolex:LexicalSense ;
                  rdfs:label "marcha: progresion armonica"@es ;
                  skos:definition "repeticion simetrica de un modelo (diseno) en diferentes grados"@es ;
                  ontolex:reference melcior:ProgresionArmonica .


###  http://leximus.es/source/melcior1859#Marcha_s3
melcior:Marcha_s3 rdf:type owl:NamedIndividual ,
                           ontolex:LexicalSense ;
                  rdfs:label "marcha: movimiento de las partes"@es ;
                  skos:definition "como se mueven las partes de una composicion ('marcha diatonica de las partes', 'marcha del bajo fundamental')"@es ;
                  ontolex:reference melcior:MovimientoArmonico .


