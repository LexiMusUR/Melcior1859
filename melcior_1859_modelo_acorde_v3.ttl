@prefix : <http://leximus.es/source/melcior1859/acorde-v3#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix cidoc: <http://www.cidoc-crm.org/cidoc-crm/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix leximus: <http://leximus.es/ontology#> .
@prefix melcior: <http://leximus.es/source/melcior1859#> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@base <http://leximus.es/source/melcior1859/acorde-v3> .

<http://leximus.es/source/melcior1859/acorde-v3> rdf:type owl:Ontology ;
                                                  rdfs:comment "Reconstruccion ontologica del concepto de acorde y su entorno conceptual a partir del Diccionario enciclopedico de la musica (Melcior, 1859). v3 amplia el modelo con clases emergentes del analisis proposicional."@es ;
                                                  rdfs:label "Modelo de ACORDE — Melcior 1859 (v3)"@es ;
                                                  dcterms:creator 
                                                  dcterms:rights "CC BY 4.0 — https://creativecommons.org/licenses/by/4.0/" ;
                                                  dcterms:isPartOf "Proyecto LexiMus PID2022-139589NB-C32, MCIN/AEI/10.13039/501100011033/FEDER, UE" ;
                                                  prov:wasDerivedFrom "Melcior, C. J. (1859). Diccionario enciclopedico de la musica"@es ;
                                                  prov:wasGeneratedBy <http://leximus.es/project/sp2> .

#################################################################
#    Annotation properties
#################################################################

###  http://leximus.es/ontology#nivelEvidencia
leximus:nivelEvidencia rdf:type owl:AnnotationProperty ;
                        rdfs:comment "TEXTUAL (la fuente lo dice), INFERENCIA (anadido por el analista), HERENCIA (de clase padre)."@es ;
                        rdfs:label "nivel de evidencia"@es .


###  http://www.cidoc-crm.org/cidoc-crm/P67_refers_to
cidoc:P67_refers_to rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#altLabel
skos:altLabel rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#closeMatch
skos:closeMatch rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#definition
skos:definition rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#example
skos:example rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#related
skos:related rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/lemon/ontolex#canonicalForm
ontolex:canonicalForm rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/lemon/ontolex#reference
ontolex:reference rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/lemon/ontolex#sense
ontolex:sense rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/lemon/ontolex#writtenRep
ontolex:writtenRep rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/prov#wasDerivedFrom
prov:wasDerivedFrom rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/prov#wasGeneratedBy
prov:wasGeneratedBy rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://leximus.es/ontology#contieneTipo
leximus:contieneTipo rdf:type owl:ObjectProperty ;
                     rdfs:comment "Una clasificacion contiene un tipo como miembro."@es ;
                     rdfs:label "contiene tipo"@es .


###  http://leximus.es/ontology#cualidadAtribuida
leximus:cualidadAtribuida rdf:type owl:ObjectProperty ;
                          rdfs:domain melcior:ValoracionEstetica ;
                          rdfs:range melcior:CualidadPerceptiva ;
                          rdfs:label "cualidad atribuida"@es .


###  http://leximus.es/ontology#ejecuta
leximus:ejecuta rdf:type owl:ObjectProperty ;
                rdfs:domain melcior:Parte ;
                rdfs:range melcior:Nota ;
                rdfs:comment "La parte ejecuta (toca/canta) notas. Relacion agentiva: la parte produce la nota en la partitura."@es ;
                rdfs:label "ejecuta"@es .


###  http://leximus.es/ontology#esAdoptadaPor
leximus:esAdoptadaPor rdf:type owl:ObjectProperty ;
                      rdfs:domain cidoc:E89_Propositional_Object ;
                      rdfs:range prov:Agent ;
                      rdfs:comment "El autor que adopta/acepta la proposicion en su texto."@es ;
                      rdfs:label "es adoptada por"@es .


###  http://leximus.es/ontology#esAlteracionDe
leximus:esAlteracionDe rdf:type owl:ObjectProperty ;
                       rdfs:comment "Relacion entre un acorde alterado y el acorde primitivo del que procede."@es ;
                       rdfs:label "es alteracion de"@es .


###  http://leximus.es/ontology#esAplicacionDe
leximus:esAplicacionDe rdf:type owl:ObjectProperty ;
                       rdfs:comment "Conecta un evento en partitura (E7) con la regla del diccionario (E29) que instancia. Capa futura."@es ;
                       rdfs:label "es aplicacion de"@es .


###  http://leximus.es/ontology#esAtribuidaA
leximus:esAtribuidaA rdf:type owl:ObjectProperty ;
                     rdfs:domain cidoc:E89_Propositional_Object ;
                     rdfs:range prov:Agent ;
                     rdfs:comment "El autor al que se atribuye la proposicion (no necesariamente quien la escribe)."@es ;
                     rdfs:label "es atribuida a"@es .


###  http://leximus.es/ontology#tienePorObjeto
leximus:tienePorObjeto rdf:type owl:ObjectProperty ;
                      rdfs:label "es la ciencia de"@es .


###  http://leximus.es/ontology#esRechazadaPor
leximus:esRechazadaPor rdf:type owl:ObjectProperty ;
                       rdfs:domain cidoc:E89_Propositional_Object ;
                       rdfs:range prov:Agent ;
                       rdfs:comment "El autor que explicitamente rechaza la proposicion."@es ;
                       rdfs:label "es rechazada por"@es .


###  http://leximus.es/ontology#esUnMecanismoDe
leximus:esUnMecanismoDe rdf:type owl:ObjectProperty ;
                        rdfs:comment "Relacion entre una regla/procedimiento especifico y el fenomeno mas amplio que produce."@es ;
                        rdfs:label "es un mecanismo de"@es .


###  http://leximus.es/ontology#forma
leximus:forma rdf:type owl:ObjectProperty ;
              rdfs:domain melcior:Nota ;
              rdfs:range melcior:Acorde ;
              rdfs:comment "Relacion resultativa: las notas simultaneas forman un acorde. El acorde es resultado, no premisa."@es ;
              rdfs:label "forma"@es .


###  http://leximus.es/ontology#gobernadoPor
leximus:gobernadoPor rdf:type owl:ObjectProperty ;
                     rdfs:domain melcior:MovimientoArmonico ;
                     rdfs:range melcior:ReglaArmonica ;
                     rdfs:comment "El movimiento de las partes esta gobernado por reglas armonicas."@es ;
                     rdfs:label "gobernado por"@es .


###  http://leximus.es/ontology#identificaAplicacionDe
leximus:identificaAplicacionDe rdf:type owl:ObjectProperty ;
                               rdfs:comment "Conecta un claim analitico (E89) con el evento en partitura (E7) sobre el que se pronuncia. Capa futura."@es ;
                               rdfs:label "identifica aplicacion de"@es .


###  http://leximus.es/ontology#opuestoDe
leximus:opuestoDe rdf:type owl:ObjectProperty ,
                           owl:SymmetricProperty ;
                  rdfs:label "opuesto de"@es .


###  http://leximus.es/ontology#permiteProceso
leximus:permiteProceso rdf:type owl:ObjectProperty ;
                       rdfs:label "permite proceso"@es .


###  http://leximus.es/ontology#precede
leximus:precede rdf:type owl:ObjectProperty ,
                         owl:TransitiveProperty ;
                rdfs:comment "Orden secuencial dentro de un procedimiento."@es ;
                rdfs:label "precede"@es .


###  http://leximus.es/ontology#produceEnlace
leximus:produceEnlace rdf:type owl:ObjectProperty ;
                      rdfs:domain melcior:MovimientoArmonico ;
                      rdfs:range melcior:EnlaceArmonico ;
                      rdfs:comment "El movimiento correcto de las partes produce el enlace armonico entre acordes."@es ;
                      rdfs:label "produce enlace"@es .


###  http://leximus.es/ontology#seDerivaDe
leximus:seDerivaDe rdf:type owl:ObjectProperty ;
                   rdfs:comment "Relacion genetica: un acorde deriva de otro por adicion de intervalo."@es ;
                   rdfs:label "se deriva de"@es .


###  http://leximus.es/ontology#seMueveSegun
leximus:seMueveSegun rdf:type owl:ObjectProperty ;
                     rdfs:domain melcior:Parte ;
                     rdfs:range melcior:MovimientoArmonico ;
                     rdfs:comment "La parte se mueve de un acorde al siguiente segun un tipo de movimiento (contrario, semejante, oblicuo)."@es ;
                     rdfs:label "se mueve segun"@es .


###  http://leximus.es/ontology#seResuelveEn
leximus:seResuelveEn rdf:type owl:ObjectProperty ;
                     rdfs:domain melcior:AcordeDisonante ;
                     rdfs:comment "Todo acorde disonante se resuelve por 5.a inferior o 4.a superior."@es ;
                     rdfs:label "se resuelve en"@es .


###  http://leximus.es/ontology#sujetoARegla
leximus:sujetoARegla rdf:type owl:ObjectProperty ;
                     rdfs:comment "La entidad musical esta sujeta a las restricciones de una regla armonica (E29)."@es ;
                     rdfs:label "sujeto a regla"@es .


###  http://leximus.es/ontology#sujetoDeValoracion
leximus:sujetoDeValoracion rdf:type owl:ObjectProperty ;
                           rdfs:domain melcior:ValoracionEstetica ;
                           rdfs:comment "La entidad musical evaluada (un tipo de acorde, un intervalo, una combinacion)."@es ;
                           rdfs:label "sujeto de valoracion"@es .


###  http://leximus.es/ontology#tieneComponente
leximus:tieneComponente rdf:type owl:ObjectProperty ;
                        rdfs:comment "Relacion parte-todo: una estructura musical contiene un componente constitutivo."@es ;
                        rdfs:label "tiene componente"@es .


###  http://leximus.es/ontology#tienePropiedad
leximus:tienePropiedad rdf:type owl:ObjectProperty ;
                       rdfs:comment "Relacion entre una clase musical y una cualidad que le es constitutiva."@es ;
                       rdfs:label "tiene propiedad"@es .


#################################################################
#    Data properties
#################################################################

###  http://leximus.es/ontology#sinEntradaPropia
leximus:sinEntradaPropia rdf:type owl:DatatypeProperty ;
                             rdfs:range xsd:boolean ;
                             rdfs:comment "true cuando el concepto es usado como constitutivo pero no tiene entrada definitoria en este diccionario. Marca un hueco que otro diccionario del corpus puede llenar."@es ;
                             rdfs:label "sin entrada propia"@es .


###  http://leximus.es/ontology#causa
leximus:causa rdf:type owl:DatatypeProperty ;
              rdfs:range rdfs:Literal ;
              rdfs:comment "Causa o fundamento que Melcior atribuye a una propiedad o fenomeno."@es ;
              rdfs:label "causa"@es .


###  http://leximus.es/ontology#condicion
leximus:condicion rdf:type owl:DatatypeProperty ;
                  rdfs:domain melcior:ValoracionEstetica ;
                  rdfs:range rdfs:Literal ;
                  rdfs:comment "Condicion bajo la cual se aplica la cualidad. Vacio = inherente; presente = condicional."@es ;
                  rdfs:label "condicion"@es .


###  http://leximus.es/ontology#determinaModo
leximus:determinaModo rdf:type owl:DatatypeProperty ;
                      rdfs:domain melcior:AcordeConsonante ;
                      rdfs:range rdfs:Literal ;
                      rdfs:label "determina modo"@es .


###  http://leximus.es/ontology#fuenteEntry
leximus:fuenteEntry rdf:type owl:DatatypeProperty ;
                    rdfs:range rdfs:Literal ;
                    rdfs:comment "xml:id de la entrada TEI de la que se extrae la informacion (e.g. 'melcior_1859_acorde')."@es ;
                    rdfs:label "entrada fuente"@es .


###  http://leximus.es/ontology#necesitaPreparacion
leximus:necesitaPreparacion rdf:type owl:DatatypeProperty ;
                            rdfs:range xsd:boolean ;
                            rdfs:label "necesita preparacion"@es .


###  http://leximus.es/ontology#ordenEnClasificacion
leximus:ordenEnClasificacion rdf:type owl:DatatypeProperty ;
                             rdfs:range xsd:integer ;
                             rdfs:comment "Numero de orden que Melcior/Reicha asignan al acorde disonante."@es ;
                             rdfs:label "orden en clasificacion"@es .


###  http://leximus.es/ontology#ordenEnProcedimiento
leximus:ordenEnProcedimiento rdf:type owl:DatatypeProperty ;
                             rdfs:range xsd:integer ;
                             rdfs:label "orden en procedimiento"@es .


###  http://leximus.es/ontology#polaridad
leximus:polaridad rdf:type owl:DatatypeProperty ;
                  rdfs:range rdfs:Literal ;
                  rdfs:comment "Orientacion valorativa: positiva, negativa o neutra."@es ;
                  rdfs:label "polaridad"@es .


###  http://leximus.es/ontology#seCompone
leximus:seCompone rdf:type owl:DatatypeProperty ;
                  rdfs:range rdfs:Literal ;
                  rdfs:comment "Descripcion de la estructura intervalica del acorde."@es ;
                  rdfs:label "se compone de"@es .


###  http://leximus.es/ontology#patronPredicativo
leximus:patronPredicativo rdf:type owl:DatatypeProperty ;
                          rdfs:range rdfs:Literal ;
                          rdfs:comment "INHERENTE (propiedad estable del tipo), CONDICIONAL (depende del manejo), RELACIONAL (depende de la mezcla)."@es ;
                          rdfs:label "patron predicativo"@es .


###  http://leximus.es/ontology#valoracionDelAutor
leximus:valoracionDelAutor rdf:type owl:DatatypeProperty ;
                           rdfs:range rdfs:Literal ;
                           rdfs:comment "Juicio explicito del autor del diccionario sobre la proposicion citada."@es ;
                           rdfs:label "valoracion del autor"@es .


#################################################################
#    Classes
#################################################################

###  http://leximus.es/source/melcior1859#Acorde
melcior:Acorde rdf:type owl:Class ;
               rdfs:subClassOf cidoc:E73_Information_Object .


###  http://leximus.es/source/melcior1859#Acorde4aAumentada
melcior:Acorde4aAumentada rdf:type owl:Class ;
                          rdfs:subClassOf melcior:AcordeDisonanteAlterado ;
                          rdfs:label "acorde de 4.a aumentada"@es ;
                          skos:definition "7.a dominante con 5.a bajada en el bajo"@es ;
                          skos:example "Reb-Fa-Sol-Si"@es .


###  http://leximus.es/source/melcior1859#Acorde5aAumentadaCon7a
melcior:Acorde5aAumentadaCon7a rdf:type owl:Class ;
                               rdfs:subClassOf melcior:AcordeDisonanteAlterado ;
                               rdfs:label "acorde de 5.a aumentada con 7.a"@es ;
                               skos:definition "7.a dominante con 5.a subida"@es ;
                               skos:example "Sol-Fa-Si-Re#"@es .


###  http://leximus.es/source/melcior1859#Acorde6aAumentada
melcior:Acorde6aAumentada rdf:type owl:Class ;
                          rdfs:subClassOf melcior:AcordeDisonanteAlterado .


###  http://leximus.es/source/melcior1859#AcordeAlteradoAscendente
melcior:AcordeAlteradoAscendente rdf:type owl:Class ;
                                 rdfs:subClassOf melcior:AcordeDisonanteAlterado ;
                                 rdfs:label "acorde alterado ascendente"@es ;
                                 skos:definition "acorde cuya 5.a ha subido un semitono"@es .


###  http://leximus.es/source/melcior1859#AcordeAlteradoDescendente
melcior:AcordeAlteradoDescendente rdf:type owl:Class ;
                                  rdfs:subClassOf melcior:AcordeDisonanteAlterado ;
                                  rdfs:label "acorde alterado descendente"@es ;
                                  skos:definition "acorde cuya 5.a ha bajado un semitono"@es .


###  http://leximus.es/source/melcior1859#AcordeCompleto
melcior:AcordeCompleto rdf:type owl:Class ;
                       rdfs:subClassOf melcior:Acorde .


###  http://leximus.es/source/melcior1859#AcordeConsonante
melcior:AcordeConsonante rdf:type owl:Class ;
                         owl:equivalentClass melcior:Triada ;
                         rdfs:subClassOf melcior:Acorde .


###  http://leximus.es/source/melcior1859#AcordeDiminuto
melcior:AcordeDiminuto rdf:type owl:Class ;
                       rdfs:subClassOf melcior:AcordeDisonantePrimitivo .


###  http://leximus.es/source/melcior1859#AcordeDirecto
melcior:AcordeDirecto rdf:type owl:Class ;
                      rdfs:subClassOf melcior:Acorde .


###  http://leximus.es/source/melcior1859#AcordeDisonante
melcior:AcordeDisonante rdf:type owl:Class ;
                        rdfs:subClassOf melcior:Acorde .


###  http://leximus.es/source/melcior1859#AcordeDisonanteAlterado
melcior:AcordeDisonanteAlterado rdf:type owl:Class ;
                                rdfs:subClassOf melcior:AcordeDisonante .


###  http://leximus.es/source/melcior1859#AcordeDisonantePrimitivo
melcior:AcordeDisonantePrimitivo rdf:type owl:Class ;
                                 rdfs:subClassOf melcior:AcordeDisonante .


###  http://leximus.es/source/melcior1859#AcordeImperfecto
melcior:AcordeImperfecto rdf:type owl:Class ;
                         rdfs:subClassOf melcior:Acorde .


###  http://leximus.es/source/melcior1859#AcordeInvertido
melcior:AcordeInvertido rdf:type owl:Class ;
                        rdfs:subClassOf melcior:Acorde .


###  http://leximus.es/source/melcior1859#AcordePerfectoMayor
melcior:AcordePerfectoMayor rdf:type owl:Class ;
                            rdfs:subClassOf melcior:AcordeConsonante .


###  http://leximus.es/source/melcior1859#AcordePerfectoMenor
melcior:AcordePerfectoMenor rdf:type owl:Class ;
                            rdfs:subClassOf melcior:AcordeConsonante .


###  http://leximus.es/source/melcior1859#ArmoniaAscendiente
melcior:ArmoniaAscendiente rdf:type owl:Class ;
                           rdfs:subClassOf melcior:ReglaDeEncadenamiento .


###  http://leximus.es/source/melcior1859#ArmoniaDescendiente
melcior:ArmoniaDescendiente rdf:type owl:Class ;
                            rdfs:subClassOf melcior:ReglaDeEncadenamiento .


###  http://leximus.es/source/melcior1859#BajoFundamental
melcior:BajoFundamental rdf:type owl:Class ;
                        rdfs:subClassOf cidoc:E73_Information_Object .


###  http://leximus.es/source/melcior1859#Cadencia
melcior:Cadencia rdf:type owl:Class ;
                 rdfs:subClassOf cidoc:E73_Information_Object .


###  http://leximus.es/source/melcior1859#CualidadPerceptiva
melcior:CualidadPerceptiva rdf:type owl:Class ;
                           rdfs:comment "No es E73 ni E28: es una cualidad predicada por el autor. Tiene polaridad (positiva/negativa/neutra). En CIDOC podria mapearse a E55 Type, pero aqui se modela como clase propia porque Melcior le da un papel argumentativo central."@es ;
                           rdfs:label "cualidad perceptiva"@es ;
                           skos:definition "propiedad estetica o sensorial que Melcior atribuye a un acorde, intervalo o combinacion armonica"@es .


###  http://leximus.es/source/melcior1859#EnlaceArmonico
melcior:EnlaceArmonico rdf:type owl:Class ;
                       rdfs:subClassOf cidoc:E73_Information_Object .


###  http://leximus.es/source/melcior1859#FaseDeProcedimiento
melcior:FaseDeProcedimiento rdf:type owl:Class ;
                            rdfs:subClassOf cidoc:E29_Design_or_Procedure ;
                            rdfs:label "fase de procedimiento"@es ;
                            skos:definition "paso individual dentro de un procedimiento secuencial"@es .


###  http://leximus.es/source/melcior1859#Inversion
melcior:Inversion rdf:type owl:Class ;
                  rdfs:subClassOf cidoc:E29_Design_or_Procedure .


###  http://leximus.es/source/melcior1859#InversionDeAcorde
melcior:InversionDeAcorde rdf:type owl:Class ;
                          rdfs:subClassOf melcior:Inversion ;
                          leximus:nivelEvidencia "TEXTUAL"@es ;
                          rdfs:comment "Melcior: 'el acorde Do Mi Sol, invertido en esta forma: Mi, Sol, Do, o Sol, Do, Mi, cambia de denominacion, y forma una variedad en la armonia'. La inversion NO cambia la naturaleza del acorde. Descubrimiento atribuido a Rameau."@es ;
                          rdfs:label "inversion de acorde"@es ;
                          skos:definition "operacion de colocar las notas de un acorde en distinta situacion del orden directo"@es .


###  http://leximus.es/source/melcior1859#InversionDeIntervalo
melcior:InversionDeIntervalo rdf:type owl:Class ;
                             rdfs:subClassOf melcior:Inversion ;
                             leximus:nivelEvidencia "TEXTUAL"@es ;
                             rdfs:comment "Melcior: 'el intervalo de mi tercera mayor en el orden directo, se transforma en 6.a menor al invertirlo'. La inversion CAMBIA el intervalo."@es ;
                             rdfs:label "inversion de intervalo"@es ;
                             skos:definition "operacion que transforma un intervalo en su complementario dentro de la octava"@es .


###  http://leximus.es/source/melcior1859#Ligadura
melcior:Ligadura rdf:type owl:Class ;
                 rdfs:subClassOf cidoc:E73_Information_Object .


###  http://leximus.es/source/melcior1859#MayorCon5aAumentada
melcior:MayorCon5aAumentada rdf:type owl:Class ;
                            rdfs:subClassOf melcior:AcordeAlteradoAscendente .


###  http://leximus.es/source/melcior1859#MayorCon5aDiminuta
melcior:MayorCon5aDiminuta rdf:type owl:Class ;
                           rdfs:subClassOf melcior:AcordeAlteradoDescendente .


###  http://leximus.es/source/melcior1859#ModeloDeProgresion
melcior:ModeloDeProgresion rdf:type owl:Class .


###  http://leximus.es/source/melcior1859#MovimientoArmonico
melcior:MovimientoArmonico rdf:type owl:Class ;
                           rdfs:subClassOf cidoc:E73_Information_Object .


###  http://leximus.es/source/melcior1859#MovimientoContrario
melcior:MovimientoContrario rdf:type owl:Class ;
                            rdfs:subClassOf melcior:MovimientoArmonico ;
                            rdfs:label "movimiento contrario"@es ;
                            skos:definition "cuando una parte sube y otra baja"@es .


###  http://leximus.es/source/melcior1859#MovimientoOblicuo
melcior:MovimientoOblicuo rdf:type owl:Class ;
                          rdfs:subClassOf melcior:MovimientoArmonico ;
                          rdfs:label "movimiento oblicuo"@es ;
                          skos:definition "cuando una parte se mueve y otra permanece quieta"@es .


###  http://leximus.es/source/melcior1859#MovimientoSemejante
melcior:MovimientoSemejante rdf:type owl:Class ;
                            rdfs:subClassOf melcior:MovimientoArmonico ;
                            rdfs:comment "Melcior (directo, f10): 'movimiento directo es cuando dos o mas partes suben o bajan juntas, pero mas comunmente se llama semejante'."@es ;
                            rdfs:label "movimiento semejante"@es ;
                            skos:altLabel "movimiento directo"@es ;
                            skos:definition "cuando ambas partes van en la misma direccion"@es .


###  http://leximus.es/source/melcior1859#Nota
melcior:Nota rdf:type owl:Class ;
             rdfs:subClassOf cidoc:E73_Information_Object .


###  http://leximus.es/source/melcior1859#NotaExtranaAlAcorde
melcior:NotaExtranaAlAcorde rdf:type owl:Class ;
                            rdfs:subClassOf cidoc:E73_Information_Object .


###  http://leximus.es/source/melcior1859#NotaFundamental
melcior:NotaFundamental rdf:type owl:Class ;
                        rdfs:label "nota fundamental"@es ;
                        skos:altLabel "nota generante"@es ;
                        skos:definition "sonido que sirve de fundamento a acorde o tono"@es .


###  http://leximus.es/source/melcior1859#NovenaMayor
melcior:NovenaMayor rdf:type owl:Class ;
                    rdfs:subClassOf melcior:AcordeDisonantePrimitivo .


