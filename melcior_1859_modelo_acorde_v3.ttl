melcior:ModulacionEnarmonicaPor6a rdf:type owl:NamedIndividual ;
                                  rdfs:label "modulacion enarmonica por 6.a aumentada"@es .


###  http://leximus.es/source/melcior1859#ModulacionEnarmonicaPorSeptima
melcior:ModulacionEnarmonicaPorSeptima rdf:type owl:NamedIndividual ;
                                       rdfs:label "modulacion enarmonica por 7.a disminuida"@es .


