###  http://leximus.es/source/melcior1859#Grato
melcior:Grato rdf:type owl:NamedIndividual ,
                       melcior:CualidadPerceptiva ;
              leximus:polaridad "positiva"@es ;
              rdfs:label "grato"@es ;
              skos:closeMatch melcior:Agradable .


###  http://leximus.es/source/melcior1859#IdentidadAcordeBajoInversion
melcior:IdentidadAcordeBajoInversion rdf:type owl:NamedIndividual ,
                                              cidoc:E89_Propositional_Object ;
                                     leximus:esAdoptadaPor melcior:Melcior ;
                                     leximus:nivelEvidencia "TEXTUAL"@es ;
                                     cidoc:P67_refers_to melcior:Acorde ,
                                                         melcior:Inversion ;
                                     rdfs:comment "Melcior (acorde, f100): 'los inexpertos ven en ellas unos nuevos acordes que al parecer son distintos, pero teniendo presente que los acordes se forman subiendo de tercera en tercera no podran equivocarse en su naturaleza'. La inversion cambia la disposicion, no la identidad. El criterio de identificacion es la reduccion a terceras."@es ;
                                     rdfs:label "la inversion no crea un acorde nuevo"@es .


###  http://leximus.es/source/melcior1859#Insoportable
melcior:Insoportable rdf:type owl:NamedIndividual ,
                              melcior:CualidadPerceptiva ;
                     leximus:polaridad "negativa"@es ;
                     rdfs:label "insoportable"@es .


###  http://leximus.es/source/melcior1859#Inversion
melcior:Inversion rdf:type owl:NamedIndividual ;
                  leximus:fuenteEntry "melcior_1859_inversion" .


###  http://leximus.es/source/melcior1859#Inversion_s1
melcior:Inversion_s1 rdf:type owl:NamedIndividual ,
                              ontolex:LexicalSense ;
                     rdfs:label "inversion: de intervalo"@es ;
                     skos:definition "el intervalo se transforma en su complementario (3.a mayor -> 6.a menor)"@es ;
                     ontolex:reference melcior:InversionDeIntervalo .


###  http://leximus.es/source/melcior1859#Inversion_s2
melcior:Inversion_s2 rdf:type owl:NamedIndividual ,
                              ontolex:LexicalSense ;
                     rdfs:label "inversion: de acorde"@es ;
                     skos:definition "las notas del acorde se colocan en distinta situacion; cambia la denominacion pero no la naturaleza"@es ;
                     ontolex:reference melcior:InversionDeAcorde .


