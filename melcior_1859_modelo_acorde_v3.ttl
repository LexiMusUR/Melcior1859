melcior:NovenaMenor rdf:type owl:Class ;
                    rdfs:subClassOf melcior:AcordeDisonantePrimitivo .


###  http://leximus.es/source/melcior1859#NovenaMenorCon5aAumentada
melcior:NovenaMenorCon5aAumentada rdf:type owl:Class ;
                                  rdfs:subClassOf melcior:AcordeAlteradoAscendente .


###  http://leximus.es/source/melcior1859#NovenaMenorCon5aDiminuta
melcior:NovenaMenorCon5aDiminuta rdf:type owl:Class ;
                                 rdfs:subClassOf melcior:AcordeAlteradoDescendente .


###  http://leximus.es/source/melcior1859#Parte
melcior:Parte rdf:type owl:Class ;
              rdfs:subClassOf cidoc:E73_Information_Object .


###  http://leximus.es/source/melcior1859#ProgresionArmonica
melcior:ProgresionArmonica rdf:type owl:Class ;
                           rdfs:subClassOf cidoc:E73_Information_Object .


###  http://leximus.es/source/melcior1859#ProhibicionFalsaRelacion
melcior:ProhibicionFalsaRelacion rdf:type owl:Class ;
                                 rdfs:subClassOf melcior:ReglaArmonica .


###  http://leximus.es/source/melcior1859#ProhibicionQuintasOctavasSeguidas
melcior:ProhibicionQuintasOctavasSeguidas rdf:type owl:Class ;
                                          rdfs:subClassOf melcior:ReglaArmonica .


###  http://leximus.es/source/melcior1859#ReglaArmonica
melcior:ReglaArmonica rdf:type owl:Class ;
                      rdfs:subClassOf cidoc:E29_Design_or_Procedure ;
                      rdfs:comment "En el diccionario, las reglas son E29: procedimientos formulados ('todo acorde disonante se resuelve por 5.a inferior o 4.a superior'). Su aplicacion a una partitura concreta sera un E7 Activity (capa futura)."@es ;
                      rdfs:label "regla armonica"@es ;
                      skos:definition "procedimiento prescriptivo para el manejo de acordes"@es .


###  http://leximus.es/source/melcior1859#ReglaDeEncadenamiento
melcior:ReglaDeEncadenamiento rdf:type owl:Class ;
                              rdfs:subClassOf melcior:ReglaArmonica .


###  http://leximus.es/source/melcior1859#Resonancia
melcior:Resonancia rdf:type owl:Class ;
                   rdfs:comment "Fenomeno fisico del que se origina el acorde perfecto."@es ;
                   rdfs:label "resonancia"@es .


###  http://leximus.es/source/melcior1859#Septima2aEspecie
melcior:Septima2aEspecie rdf:type owl:Class ;
                         rdfs:subClassOf melcior:AcordeDisonantePrimitivo .


###  http://leximus.es/source/melcior1859#Septima3aEspecie
melcior:Septima3aEspecie rdf:type owl:Class ;
                         rdfs:subClassOf melcior:AcordeDisonantePrimitivo .


###  http://leximus.es/source/melcior1859#Septima4aEspecie
melcior:Septima4aEspecie rdf:type owl:Class ;
                         rdfs:subClassOf melcior:AcordeDisonantePrimitivo .


###  http://leximus.es/source/melcior1859#Septima4aEspecieCon5aAumentada
melcior:Septima4aEspecieCon5aAumentada rdf:type owl:Class ;
                                       rdfs:subClassOf melcior:AcordeAlteradoAscendente .


###  http://leximus.es/source/melcior1859#SeptimaDisminuida
melcior:SeptimaDisminuida rdf:type owl:Class ;
                          rdfs:subClassOf melcior:AcordeDisonantePrimitivo .


###  http://leximus.es/source/melcior1859#SeptimaDominante
melcior:SeptimaDominante rdf:type owl:Class ;
                         rdfs:subClassOf melcior:AcordeDisonantePrimitivo .


###  http://leximus.es/source/melcior1859#SeptimaDominanteCon5aAumentada
melcior:SeptimaDominanteCon5aAumentada rdf:type owl:Class ;
                                       rdfs:subClassOf melcior:AcordeAlteradoAscendente .


###  http://leximus.es/source/melcior1859#SeptimaDominanteCon5aDiminuta
melcior:SeptimaDominanteCon5aDiminuta rdf:type owl:Class ;
                                      rdfs:subClassOf melcior:AcordeAlteradoDescendente .


###  http://leximus.es/source/melcior1859#Sonido
melcior:Sonido rdf:type owl:Class ;
               rdfs:subClassOf cidoc:E73_Information_Object .


###  http://leximus.es/source/melcior1859#TratamientoDeLaDisonancia
melcior:TratamientoDeLaDisonancia rdf:type owl:Class ;
                                  rdfs:subClassOf melcior:ReglaArmonica .


###  http://leximus.es/source/melcior1859#Triada
melcior:Triada rdf:type owl:Class .


###  http://leximus.es/source/melcior1859#ValoracionEstetica
melcior:ValoracionEstetica rdf:type owl:Class ;
                           rdfs:comment "Reificacion necesaria porque la misma entidad musical puede recibir cualidades opuestas segun las condiciones. P. ej., el acorde disonante es 'insoportable' sin preparacion pero produce 'bellisimo efecto' con ella. Sin reificar, estas dos predicaciones serian contradictorias."@es ;
                           rdfs:label "valoracion estetica"@es ;
                           skos:definition "predicacion de una cualidad perceptiva sobre un acorde o combinacion armonica, con condiciones opcionales"@es .


###  http://www.cidoc-crm.org/cidoc-crm/E29_Design_or_Procedure
cidoc:E29_Design_or_Procedure rdf:type owl:Class .


###  http://www.cidoc-crm.org/cidoc-crm/E55_Type
cidoc:E55_Type rdf:type owl:Class .


###  http://www.cidoc-crm.org/cidoc-crm/E73_Information_Object
cidoc:E73_Information_Object rdf:type owl:Class .


###  http://www.cidoc-crm.org/cidoc-crm/E89_Propositional_Object
cidoc:E89_Propositional_Object rdf:type owl:Class .


###  http://www.w3.org/ns/lemon/ontolex#Form
ontolex:Form rdf:type owl:Class .


###  http://www.w3.org/ns/lemon/ontolex#LexicalEntry
ontolex:LexicalEntry rdf:type owl:Class .


###  http://www.w3.org/ns/lemon/ontolex#LexicalSense
ontolex:LexicalSense rdf:type owl:Class .


###  http://www.w3.org/ns/prov#Agent
prov:Agent rdf:type owl:Class .


#################################################################
#    Individuals
#################################################################

###  http://leximus.es/source/melcior1859#Acorde
melcior:Acorde rdf:type owl:NamedIndividual ;
               leximus:fuenteEntry "melcior_1859_acorde" .


###  http://leximus.es/source/melcior1859#Acorde6aAumentada
melcior:Acorde6aAumentada rdf:type owl:NamedIndividual ;
                          leximus:permiteProceso melcior:ModulacionEnarmonicaPor6a .


###  http://leximus.es/source/melcior1859#AcordeCompleto
melcior:AcordeCompleto rdf:type owl:NamedIndividual ;
                       leximus:opuestoDe melcior:AcordeImperfecto .


###  http://leximus.es/source/melcior1859#AcordeConsonante
melcior:AcordeConsonante rdf:type owl:NamedIndividual ;
                         leximus:opuestoDe melcior:AcordeDisonante ;
                         leximus:tienePropiedad melcior:PerfeccionMusical ;
                         leximus:determinaModo "por su 3.a mayor o menor"@es .


###  http://leximus.es/source/melcior1859#AcordeDiminuto
melcior:AcordeDiminuto rdf:type owl:NamedIndividual ;
                       leximus:seResuelveEn melcior:AcordeConsonante ,
                                            melcior:SeptimaDominante ;
                       leximus:necesitaPreparacion "false"^^xsd:boolean ;
                       leximus:ordenEnClasificacion 1 .


###  http://leximus.es/source/melcior1859#AcordeDirecto
melcior:AcordeDirecto rdf:type owl:NamedIndividual ;
                      leximus:opuestoDe melcior:AcordeInvertido ;
                      leximus:fuenteEntry "melcior_1859_directo" .


###  http://leximus.es/source/melcior1859#AcordeDisonante
melcior:AcordeDisonante rdf:type owl:NamedIndividual ;
                        leximus:opuestoDe melcior:AcordeConsonante .


###  http://leximus.es/source/melcior1859#AcordeDisonanteAlterado
melcior:AcordeDisonanteAlterado rdf:type owl:NamedIndividual ;
                                leximus:opuestoDe melcior:AcordeDisonantePrimitivo .


###  http://leximus.es/source/melcior1859#AcordeDisonantePrimitivo
melcior:AcordeDisonantePrimitivo rdf:type owl:NamedIndividual ;
                                 leximus:opuestoDe melcior:AcordeDisonanteAlterado .


###  http://leximus.es/source/melcior1859#AcordeImperfecto
melcior:AcordeImperfecto rdf:type owl:NamedIndividual ;
                         leximus:opuestoDe melcior:AcordeCompleto ;
                         leximus:fuenteEntry "melcior_1859_imperfecto" .


###  http://leximus.es/source/melcior1859#AcordeInvertido
melcior:AcordeInvertido rdf:type owl:NamedIndividual ;
                        leximus:opuestoDe melcior:AcordeDirecto ;
                        leximus:fuenteEntry "melcior_1859_inversion" .


###  http://leximus.es/source/melcior1859#AcordePerfectoMayor
melcior:AcordePerfectoMayor rdf:type owl:NamedIndividual ;
                            leximus:seCompone "fundamental + 3.a mayor + 5.a justa"@es .


###  http://leximus.es/source/melcior1859#AcordePerfectoMenor
melcior:AcordePerfectoMenor rdf:type owl:NamedIndividual ;
                            leximus:seCompone "fundamental + 3.a menor + 5.a justa"@es .


###  http://leximus.es/source/melcior1859#Acorde_s1
melcior:Acorde_s1 rdf:type owl:NamedIndividual ,
                           ontolex:LexicalSense ;
                  rdfs:label "acorde: adicion de sonidos simultaneos"@es ;
                  skos:definition "adicion de dos o mas sonidos a otro sonido dado, tocados o cantados simultaneamente, de los que resulte belleza en su conjunto"@es ;
                  ontolex:reference melcior:Acorde .


###  http://leximus.es/source/melcior1859#Agradable
melcior:Agradable rdf:type owl:NamedIndividual ,
                           melcior:CualidadPerceptiva ;
                  leximus:polaridad "positiva"@es ;
                  rdfs:label "agradable"@es .


###  http://leximus.es/source/melcior1859#Armonia
melcior:Armonia rdf:type owl:NamedIndividual ,
                         cidoc:E55_Type ;
                leximus:tienePorObjeto melcior:Acorde ;
                leximus:fuenteEntry "melcior_1859_armonia" ;
                rdfs:comment "Modelada como E55 Type (tecnica general), no como E29 ni E89. Armonia es el nombre de la disciplina/tecnica, como 'oleo' o 'contrapunto'. Las reglas concretas que la componen (encadenamiento, tratamiento de disonancia, etc.) son E29 Design or Procedure. En CIDOC, P32 conecta una actividad (E7) con su tecnica general (E55); P33 la conecta con el procedimiento especifico (E29). Lema polisemico en Melcior: (1) disciplina = la ciencia de los acordes (def. Fetis adoptada, armonia f4); (2) progresion = flujo armonico concreto, como en 'armonia ascendiente'; (3) resultado sonoro (f54); (4) estilo personal (f44). Acepcion 2 se modela como subtipos de ReglaDeEncadenamiento."@es ;
                rdfs:label "armonia"@es ;
                skos:definition "la ciencia de los acordes; abarca conocimiento de acordes + habilidad para emplearlos"@es .


###  http://leximus.es/source/melcior1859#ArmoniaAscendiente
melcior:ArmoniaAscendiente rdf:type owl:NamedIndividual ;
                           leximus:opuestoDe melcior:ArmoniaDescendiente ;
                           leximus:fuenteEntry "melcior_1859_ascendiente_armonia" .


###  http://leximus.es/source/melcior1859#ArmoniaDescendiente
melcior:ArmoniaDescendiente rdf:type owl:NamedIndividual ;
                            leximus:opuestoDe melcior:ArmoniaAscendiente ;
                            leximus:fuenteEntry "melcior_1859_ascendiente_armonia" .


###  http://leximus.es/source/melcior1859#Armonia_s1
melcior:Armonia_s1 rdf:type owl:NamedIndividual ,
                            ontolex:LexicalSense ;
                   rdfs:label "armonia: disciplina"@es ;
                   skos:definition "la ciencia de los acordes"@es ;
                   ontolex:reference melcior:Armonia .


###  http://leximus.es/source/melcior1859#Armonia_s2
melcior:Armonia_s2 rdf:type owl:NamedIndividual ,
                            ontolex:LexicalSense ;
                   rdfs:label "armonia: progresion concreta"@es ;
                   skos:definition "flujo armonico concreto (armonia ascendiente/descendiente)"@es ;
                   ontolex:reference melcior:ReglaDeEncadenamiento .


###  http://leximus.es/source/melcior1859#Armonia_s3
melcior:Armonia_s3 rdf:type owl:NamedIndividual ,
                            ontolex:LexicalSense ;
                   rdfs:label "armonia: resultado sonoro"@es ;
                   skos:definition "la armonia de los acordes puede presentarse de diferentes modos"@es .


###  http://leximus.es/source/melcior1859#Armonia_s4
melcior:Armonia_s4 rdf:type owl:NamedIndividual ,
                            ontolex:LexicalSense ;
                   rdfs:label "armonia: estilo"@es ;
                   skos:definition "la armonia recibe un cierto colorido particular"@es .


###  http://leximus.es/source/melcior1859#Aspero
melcior:Aspero rdf:type owl:NamedIndividual ,
                        melcior:CualidadPerceptiva ;
               leximus:opuestoDe melcior:Dulce ;
               leximus:polaridad "negativa"@es ;
               rdfs:label "aspero / aspereza"@es .


###  http://leximus.es/source/melcior1859#BajoFundamental
melcior:BajoFundamental rdf:type owl:NamedIndividual ;
                        leximus:fuenteEntry "melcior_1859_bajo_fundamental" .


###  http://leximus.es/source/melcior1859#Bello
melcior:Bello rdf:type owl:NamedIndividual ,
                       melcior:CualidadPerceptiva ;
              leximus:sinEntradaPropia "true"^^xsd:boolean ;
              leximus:polaridad "positiva"@es ;
              leximus:nivelEvidencia "TEXTUAL"@es ;
              rdfs:comment "Estatus especial: es condicion DEFINITORIA del acorde ('de los que resulte belleza en su conjunto'), no una cualidad entre otras. Sin belleza no hay acorde, hay cacofonia. Sin embargo, Melcior NO define belleza — la trata como primitivo no analizado. Parada (1868) si la define como entrada propia: BELLEZA MUSICAL (parada_1868_belleza_musical)."@es ;
              rdfs:label "belleza / bien sonancia"@es .


###  http://leximus.es/source/melcior1859#Blando
melcior:Blando rdf:type owl:NamedIndividual ,
                        melcior:CualidadPerceptiva ;
               leximus:opuestoDe melcior:Duro ;
               leximus:sinEntradaPropia "true"^^xsd:boolean ;
               leximus:polaridad "positiva"@es ;
               rdfs:comment "Sin entrada propia. Aparece en contraste con duro (unidad, f21): 'acordes duros, si la expresion lo requiere, y de acordes blandos si la expresion es dulce'. Termino no marcado."@es ;
               rdfs:label "blando"@es .


###  http://leximus.es/source/melcior1859#Brillante
melcior:Brillante rdf:type owl:NamedIndividual ,
                           melcior:CualidadPerceptiva ;
                  leximus:polaridad "positiva"@es ;
                  rdfs:label "brillo"@es .


###  http://leximus.es/source/melcior1859#Cacofonico
melcior:Cacofonico rdf:type owl:NamedIndividual ,
                            melcior:CualidadPerceptiva ;
                   leximus:polaridad "negativa"@es ;
                   rdfs:label "cacofonico"@es .


###  http://leximus.es/source/melcior1859#Cadencia
melcior:Cadencia rdf:type owl:NamedIndividual ;
                 leximus:fuenteEntry "melcior_1859_cadencia" .


###  http://leximus.es/source/melcior1859#CadenciaInterrumpida
melcior:CadenciaInterrumpida rdf:type owl:NamedIndividual ,
                                      melcior:Cadencia ;
                             rdfs:comment "Melcior (cadencia, f15-16): 'se evita el caer al reposo, y, por lo tanto, debe continuar la armonia hasta que caiga en un acorde perfecto'."@es ;
                             rdfs:label "cadencia interrumpida"@es ;
                             skos:definition "desde la 7.a dominante, en vez de caer en acorde perfecto, salta a la 7.a dominante de otro tono"@es .


###  http://leximus.es/source/melcior1859#CadenciaPerfecta
melcior:CadenciaPerfecta rdf:type owl:NamedIndividual ,
                                  melcior:Cadencia ;
                         rdfs:comment "Melcior (cadencia, f12-14): 'Se llama cadencia perfecta el reposo que se hace al fin de una frase sobre el acorde perfecto en el orden directo, precedido del de la septima dominante sin inversion'. Tambien llamada 'autentica' (authentes = superior)."@es ;
                         rdfs:label "cadencia perfecta (= autentica)"@es ;
                         skos:definition "reposo sobre acorde perfecto directo, precedido de 7.a dominante sin inversion, cayendo en el primer tiempo"@es .


###  http://leximus.es/source/melcior1859#CadenciaPlagal
melcior:CadenciaPlagal rdf:type owl:NamedIndividual ,
                                melcior:Cadencia ;
                       rdfs:comment "Melcior (cadencia, f19-23): 'Regularmente solo se hace despues de un acorde perfecto, y al final de un compas'. Origen dorico. Los antiguos no podian concluir en menor."@es ;
                       rdfs:label "cadencia plagal"@es ;
                       skos:definition "reposo en acorde directo precedido del acorde de 4.a directo o inverso"@es .


###  http://leximus.es/source/melcior1859#CadenciaRota
melcior:CadenciaRota rdf:type owl:NamedIndividual ,
                              melcior:Cadencia ;
                     rdfs:comment "Melcior (cadencia, f17-18): 'enganan, digamoslo asi, al oido, el cual espera la caida a un acorde perfecto correspondiente a la 7.a enunciada, y oye otro distinto'."@es ;
                     rdfs:label "cadencia rota (= engano)"@es ;
                     skos:definition "de la 7.a dominante se pasa a un acorde perfecto distinto del esperado"@es .


###  http://leximus.es/source/melcior1859#Catel
melcior:Catel rdf:type owl:NamedIndividual ,
                       prov:Agent ;
              rdfs:comment "Deduce los acordes de las fracciones del monocordio."@es ;
              rdfs:label "Charles-Simon Catel" .


###  http://leximus.es/source/melcior1859#ClasificacionAcordesSegunReicha
melcior:ClasificacionAcordesSegunReicha rdf:type owl:NamedIndividual ,
                                                 cidoc:E89_Propositional_Object ;
                                        leximus:contieneTipo melcior:AcordeDiminuto ,
                                                             melcior:MayorCon5aAumentada ,
                                                             melcior:MayorCon5aDiminuta ,
                                                             melcior:NovenaMayor ,
                                                             melcior:NovenaMayorCon5aAumentada ,
                                                             melcior:NovenaMayorCon5aDiminuta ,
                                                             melcior:NovenaMenor ,
                                                             melcior:NovenaMenorCon5aAumentada ,
                                                             melcior:NovenaMenorCon5aDiminuta ,
                                                             melcior:Septima2aEspecie ,
                                                             melcior:Septima3aEspecie ,
                                                             melcior:Septima4aEspecie ,
                                                             melcior:Septima4aEspecieCon5aAumentada ,
                                                             melcior:SeptimaDominante ,
                                                             melcior:SeptimaDominanteCon5aAumentada ,
                                                             melcior:SeptimaDominanteCon5aDiminuta ;
                                        leximus:esAdoptadaPor melcior:Melcior ;
                                        leximus:esAtribuidaA melcior:Reicha ;
                                        leximus:nivelEvidencia "TEXTUAL"@es ;
                                        cidoc:P67_refers_to melcior:AcordeDisonante ;
                                        rdfs:comment "Melcior adopta la clasificacion de Reicha para los 17 tipos de acordes disonantes (7 primitivos + 10 alterados). Frase: 'siguiendo la clasificacion que hace de ellos el maestro Reicha'."@es ;
                                        rdfs:label "clasificacion de los acordes disonantes segun Reicha"@es .


###  http://leximus.es/source/melcior1859#CriticaARousseau
melcior:CriticaARousseau rdf:type owl:NamedIndividual ,
                                  cidoc:E89_Propositional_Object ;
                         leximus:esAtribuidaA melcior:Rousseau ;
                         leximus:esRechazadaPor melcior:Melcior ;
                         leximus:nivelEvidencia "TEXTUAL"@es ;
                         cidoc:P67_refers_to melcior:AcordeDisonante ;
                         rdfs:comment "Rousseau define disonancia como 'todo sonido que forma acorde desagradable'. Melcior rechaza esta definicion: 'Las disonancias no son desagradables en la musica, al contrario, la que no las tuviera, seria muy chabacana'."@es ;
                         rdfs:label "critica de Melcior a la definicion de disonancia de Rousseau"@es .


###  http://leximus.es/source/melcior1859#DefinicionFetisArmonia
melcior:DefinicionFetisArmonia rdf:type owl:NamedIndividual ,
                                        cidoc:E89_Propositional_Object ;
                               leximus:esAtribuidaA melcior:Fetis ;
                               leximus:nivelEvidencia "TEXTUAL"@es ;
                               cidoc:P67_refers_to melcior:Armonia ;
                               rdfs:label "definicion de Fetis: armonia como ciencia de los acordes"@es .


###  http://leximus.es/source/melcior1859#Desagradable
melcior:Desagradable rdf:type owl:NamedIndividual ,
                              melcior:CualidadPerceptiva ;
                     leximus:opuestoDe melcior:Agradable ;
                     leximus:polaridad "negativa"@es ;
                     rdfs:label "desagradable"@es .


###  http://leximus.es/source/melcior1859#DescubrimientoInversionesRameau
melcior:DescubrimientoInversionesRameau rdf:type owl:NamedIndividual ,
                                                 cidoc:E89_Propositional_Object ;
                                        leximus:esAdoptadaPor melcior:Melcior ;
                                        leximus:esAtribuidaA melcior:Rameau ;
                                        leximus:nivelEvidencia "TEXTUAL"@es ;
                                        cidoc:P67_refers_to melcior:Inversion ;
                                        rdfs:comment "Melcior atribuye a Rameau el descubrimiento de que los acordes invertidos son los mismos acordes en distinta disposicion, no acordes nuevos."@es ;
                                        rdfs:label "descubrimiento de Rameau: las inversiones son los mismos acordes"@es .


###  http://leximus.es/source/melcior1859#Directo_s1
melcior:Directo_s1 rdf:type owl:NamedIndividual ,
                            ontolex:LexicalSense ;
                   rdfs:label "directo: intervalo con la fundamental"@es ;
                   skos:definition "intervalo que forma una nota armonica con cualquiera otra que sea fundamental"@es .


###  http://leximus.es/source/melcior1859#Directo_s2
melcior:Directo_s2 rdf:type owl:NamedIndividual ,
                            ontolex:LexicalSense ;
                   rdfs:label "directo: acorde en posicion fundamental"@es ;
                   skos:definition "acorde cuyas partes van de lo grave al agudo sobre un sonido fundamental"@es ;
                   ontolex:reference melcior:AcordeDirecto .


###  http://leximus.es/source/melcior1859#Directo_s3
melcior:Directo_s3 rdf:type owl:NamedIndividual ,
                            ontolex:LexicalSense ;
                   rdfs:label "directo: movimiento semejante"@es ;
                   skos:definition "movimiento directo es cuando dos o mas partes suben o bajan juntas"@es ;
                   ontolex:reference melcior:MovimientoSemejante .


###  http://leximus.es/source/melcior1859#Dulce
melcior:Dulce rdf:type owl:NamedIndividual ,
                       melcior:CualidadPerceptiva ;
              leximus:polaridad "positiva"@es ;
              rdfs:label "dulce"@es .


###  http://leximus.es/source/melcior1859#Duro
melcior:Duro rdf:type owl:NamedIndividual ,
                      melcior:CualidadPerceptiva ;
             leximus:opuestoDe melcior:Blando ;
             leximus:fuenteEntry "melcior_1859_duro" ;
             leximus:polaridad "negativa"@es ;
             rdfs:comment "Melcior (duro, f1-f6): se aplica a voces, instrumentos, composiciones, intervalos y acordes. En armonia, son duros los de tritono, 5.a aumentada y disonancias mayores (f5). Pero 'son expresivas y sentimentales si se manejan bien' (f5); 'usadas oportunamente producen muy buenos efectos' (f6)."@es ;
             rdfs:label "duro / dureza"@es ;
             skos:closeMatch melcior:Aspero ;
             skos:definition "todo cuanto mortifica al oido por su aspereza"@es .


###  http://leximus.es/source/melcior1859#Encadenamiento_s1
melcior:Encadenamiento_s1 rdf:type owl:NamedIndividual ,
                                   ontolex:LexicalSense ;
                          ontolex:reference melcior:EnlaceArmonico .


###  http://leximus.es/source/melcior1859#Encantador
melcior:Encantador rdf:type owl:NamedIndividual ,
                            melcior:CualidadPerceptiva ;
                   leximus:polaridad "positiva"@es ;
                   rdfs:label "encanto"@es .


###  http://leximus.es/source/melcior1859#EnlaceArmonico
melcior:EnlaceArmonico rdf:type owl:NamedIndividual ;
                       leximus:fuenteEntry "melcior_1859_enlace_armonico" .


###  http://leximus.es/source/melcior1859#EnlaceArmonico_s1
melcior:EnlaceArmonico_s1 rdf:type owl:NamedIndividual ,
                                   ontolex:LexicalSense ;
                          rdfs:label "enlace armonico: coherencia entre acordes"@es ;
                          skos:definition "necesidad absoluta entre acordes; buen enlace produce progresion armonica"@es ;
                          ontolex:reference melcior:EnlaceArmonico .


###  http://leximus.es/source/melcior1859#Fetis
melcior:Fetis rdf:type owl:NamedIndividual ,
                       prov:Agent ;
              rdfs:comment "Define la armonia como 'la ciencia de los acordes'."@es ;
              rdfs:label "Francois-Joseph Fetis" .


###  http://leximus.es/source/melcior1859#Fluidez
melcior:Fluidez rdf:type owl:NamedIndividual ,
                         melcior:CualidadPerceptiva ;
                leximus:fuenteEntry "melcior_1859_fluidez" ;
                leximus:polaridad "positiva"@es ;
                rdfs:comment "Melcior (fluidez, f1): 'han de caminar bajo una ilacion y enlace de sonidos y de acordes, y con una marcha natural y facil, de modo que no se perciba que el compositor haya hecho esfuerzo alguno'. Antagonista: saltos incoherentes y acordes mal enlazados (f2). La fuga es el estudio mas propio para conseguirla (f3)."@es ;
                rdfs:label "fluidez"@es ;
                skos:definition "ilacion y enlace de sonidos y de acordes, con una marcha natural y facil"@es .


