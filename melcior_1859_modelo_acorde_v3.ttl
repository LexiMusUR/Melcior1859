melcior:Movimiento_s1 rdf:type owl:NamedIndividual ,
                               ontolex:LexicalSense ;
                      rdfs:label "movimiento: tempo"@es ;
                      skos:definition "grado de velocidad en la ejecucion (allegro, andante...)"@es .


###  http://leximus.es/source/melcior1859#Movimiento_s2
melcior:Movimiento_s2 rdf:type owl:NamedIndividual ,
                               ontolex:LexicalSense ;
                      rdfs:label "movimiento: direccion de las partes"@es ;
                      skos:definition "direccion en que se mueven las partes al pasar de un acorde a otro"@es ;
                      ontolex:reference melcior:MovimientoArmonico .


